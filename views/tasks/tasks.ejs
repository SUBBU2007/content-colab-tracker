<!DOCTYPE html>
<html>

<head>
  <title>All Tasks - Content Collaboration Tracker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/dashboard">Content Collaboration Tracker</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/projects">Projects</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/tasks">Tasks</a>
          </li>
          <li class="nav-item">
            <span class="nav-link text-white-50">|</span>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="container mt-4 mb-5">
    <!-- Header Section -->
    <div class="row mb-4">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h2 class="mb-1 fw-bold">All Tasks</h2>
            <p class="text-muted mb-0">View and manage all your tasks across projects</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Task Stats -->
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h4 class="fw-bold text-primary mb-1"><%= tasks.length %></h4>
            <small class="text-muted">Total Tasks</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h4 class="fw-bold text-warning mb-1"><%= tasks.filter(t => t.status === 'Pending').length %></h4>
            <small class="text-muted">Pending</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h4 class="fw-bold text-info mb-1"><%= tasks.filter(t => t.status === 'In Progress').length %></h4>
            <small class="text-muted">In Progress</small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-3">
            <h4 class="fw-bold text-success mb-1"><%= tasks.filter(t => t.status === 'Completed').length %></h4>
            <small class="text-muted">Completed</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Filter Section -->
    <div class="row mb-4">
      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-3">
            <div class="row g-3 align-items-center">
              <div class="col-md-4">
                <select class="form-select" id="filterStatus">
                  <option value="all" selected>All Status</option>
                  <option value="Pending">Pending</option>
                  <option value="In Progress">In Progress</option>
                  <option value="Completed">Completed</option>
                </select>
              </div>
              <div class="col-md-4">
                <select class="form-select" id="filterProject">
                  <option value="all" selected>All Projects</option>
                  <!-- Dynamically populated -->
                </select>
              </div>
              <div class="col-md-4">
                <select class="form-select" id="sortBy">
                  <option value="newest" selected>Sort by: Newest</option>
                  <option value="oldest">Oldest</option>
                  <option value="due_date">Due Date</option>
                  <option value="status">Status</option>
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tasks List -->
    <% if (tasks.length === 0) { %>
    <div class="row">
      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center p-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-muted mb-3" viewBox="0 0 16 16">
              <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
            </svg>
            <h4 class="mb-2">No Tasks Found</h4>
            <p class="text-muted mb-4">Start by creating a project and adding tasks to it</p>
            <a href="/projects" class="btn btn-primary">Go to Projects</a>
          </div>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="row">
      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0" id="tasksTable">
                <thead class="table-light">
                  <tr>
                    <th class="px-4 py-3" style="width: 5%">
                      <input type="checkbox" class="form-check-input">
                    </th>
                    <th class="px-4 py-3" style="width: 30%">Task Title</th>
                    <th class="px-4 py-3" style="width: 20%">Project</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Due Date</th>
                    <th class="px-4 py-3 text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% tasks.forEach(task => { %>
                  <tr data-status="<%= task.status %>" data-project="<%= task.project_id %>">
                    <td class="px-4 py-3">
                      <form action="/tasks/<%= task.task_id %>/toggle-status" method="POST" style="display: inline;">
                        <input type="checkbox" class="form-check-input" <%= task.status === 'Completed' ? 'checked' : '' %> onchange="this.form.submit()">
                      </form>
                    </td>
                    <td class="px-4 py-3">
                      <div>
                        <% if (task.status === 'Completed') { %>
                        <span class="text-decoration-line-through text-muted"><%= task.task_title %></span>
                        <% } else { %>
                        <span class="fw-semibold"><%= task.task_title %></span>
                        <% } %>
                        <% if (task.description) { %>
                        <br><small class="text-muted"><%= task.description.substring(0, 50) %><%= task.description.length > 50 ? '...' : '' %></small>
                        <% } %>
                      </div>
                    </td>
                    <td class="px-4 py-3">
                      <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="text-primary" viewBox="0 0 16 16">
                            <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2z" />
                          </svg>
                        </div>
                        <div>
                          <small class="fw-semibold d-block"><%= task.project_title %></small>
                          <small class="text-muted">Project</small>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-3">
                      <% 
            let taskStatusClass = 'warning';
            let taskStatusBg = 'warning-subtle';
            if (task.status === 'Completed') {
                taskStatusClass = 'success';
                taskStatusBg = 'success-subtle';
            } else if (task.status === 'In Progress') {
                taskStatusClass = 'info';
                taskStatusBg = 'info-subtle';
            }
            %>
                      <span class="badge bg-<%= taskStatusBg %> text-<%= taskStatusClass %>"><%= task.status %></span>
                    </td>
                    <td class="px-4 py-3">
                      <small class="text-muted">
                        <%= task.due_date ? new Date(task.due_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "Not set" %>
                      </small>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <div class="btn-group btn-group-sm">
                        <a href="/tasks/<%= task.task_id %>/edit" class="btn btn-outline-warning" title="Edit">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                          </svg>
                        </a>
                        <a href="/projects/<%= task.project_id %>" class="btn btn-outline-primary" title="View Project">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                          </svg>
                        </a>
                        <button class="btn btn-outline-danger btn-sm" onclick="deleteTask(<%= task.task_id %>)" title="Delete">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                            <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z" />
                          </svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Simple client-side filtering
    document.getElementById('filterStatus').addEventListener('change', filterTasks);
    document.getElementById('filterProject').addEventListener('change', filterTasks);

    function filterTasks() {
      const statusFilter = document.getElementById('filterStatus').value;
      const projectFilter = document.getElementById('filterProject').value;
      const rows = document.querySelectorAll('#tasksTable tbody tr');

      rows.forEach(row => {
        const status = row.getAttribute('data-status');
        const project = row.getAttribute('data-project');

        let showRow = true;

        if (statusFilter !== 'all' && status !== statusFilter) {
          showRow = false;
        }

        if (projectFilter !== 'all' && project !== projectFilter) {
          showRow = false;
        }

        row.style.display = showRow ? '' : 'none';
      });
    }

    // Delete task with confirmation
    function deleteTask(taskId) {
      if (confirm('Are you sure you want to delete this task?')) {
        // Create a form and submit it
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/tasks/${taskId}/delete`;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
</body>

</html>
</body>

</html>