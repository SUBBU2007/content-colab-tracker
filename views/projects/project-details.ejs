                            <small class="text-muted">Completed</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center p-3 bg-light rounded">
                            <h3 class="fw-bold text-warning mb-1"><%= totalTasks - completedTasks %></h3>
                            <small class="text-muted">Remaining</small>
