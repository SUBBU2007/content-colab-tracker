                    </div>
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" 
                             role="progressbar" 
                             style="width: <%= progress %>%;"
                             aria-valuenow="<%= progress %>" 
                             aria-valuemin="0" 
                             aria-valuemax="100">
