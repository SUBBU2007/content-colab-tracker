    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <h5 class="fw-semibold mb-4">Task Progress</h5>
        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <div class="text-center p-3 bg-light rounded">
              <h3 class="fw-bold text-primary mb-1"><%= totalTasks || 0 %></h3>
              <small class="text-muted">Total Tasks</small>
            </div>
          </div>
          <div class="col-md-4">
            <div class="text-center p-3 bg-light rounded">
              <h3 class="fw-bold text-success mb-1"><%= completedTasks || 0 %></h3>
              <small class="text-muted">Completed</small>
            </div>
          </div>
          <div class="col-md-4">
            <div class="text-center p-3 bg-light rounded">
              <h3 class="fw-bold text-warning mb-1"><%= (totalTasks || 0) - (completedTasks || 0) %></h3>
              <small class="text-muted">Remaining</small>
            </div>
          </div>
        </div>
        <div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">Overall Progress</small>
            <small class="fw-bold text-primary"><%= progress || 0 %>%</small>
          </div>
          <div class="progress" style="height: 25px;">
            <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: <%= progress || 0 %>%" aria-valuenow="<%= progress || 0 %>" aria-valuemin="0" aria-valuemax="100">
              <%= progress || 0 %>%
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tasks Section -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <h5 class="mb-0 fw-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
              <path d="M2.5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2h-11zm5 2h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1zm-5 1a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V3zm9-1h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1zM2 8h12v5a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V8z" />
            </svg>
            Project Tasks
          </h5>
          <a href="/projects/<%= project.project_id %>/tasks/create" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
              <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
            </svg>
            Add New Task
          </a>
        </div>
      </div>
      <div class="card-body p-0">
        <% if (tasks.length === 0) { %>
        <div class="text-center p-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-muted mb-3" viewBox="0 0 16 16">
            <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
          </svg>
          <h5 class="text-muted">No Tasks Yet</h5>
          <p class="text-muted mb-4">Get started by adding your first task to this project</p>
          <a href="/projects/<%= project.project_id %>/tasks/create" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
              <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
            </svg>
            Create First Task
          </a>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="px-4 py-3" style="width: 40%">Task Title</th>
                <th class="px-4 py-3">Assigned To</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3">Due Date</th>
                <th class="px-4 py-3 text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% tasks.forEach(task => { %>
              <tr>
                <td class="px-4 py-3">
                  <div class="d-flex align-items-center">
                    <form action="/tasks/<%= task.task_id %>/toggle-status" method="POST" style="display: inline;">
                      <input type="checkbox" class="form-check-input me-3" <%= task.status === 'Completed' ? 'checked' : '' %> onchange="this.form.submit()">
                    </form>
                    <% if (task.status === 'Completed') { %>
                    <span class="text-decoration-line-through text-muted"><%= task.task_title %></span>
                    <% } else { %>
                    <span class="fw-semibold"><%= task.task_title %></span>
                    <% } %>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-primary" viewBox="0 0 16 16">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" />
                      </svg>
                    </div>
                    <small class="text-muted">Member</small>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <% 
                                    let taskStatusClass = 'warning';
                                    let taskStatusBg = 'warning-subtle';
                                    if (task.status === 'Completed') {
                                        taskStatusClass = 'success';
                                        taskStatusBg = 'success-subtle';
                                    } else if (task.status === 'In Progress') {
                                        taskStatusClass = 'info';
                                        taskStatusBg = 'info-subtle';
                                    }
                                    %>
                  <span class="badge bg-<%= taskStatusBg %> text-<%= taskStatusClass %>"><%= task.status %></span>
                </td>
                <td class="px-4 py-3">
                  <small class="text-muted">
                    <%= task.due_date ? new Date(task.due_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "Not set" %>
                  </small>
                </td>
                <td class="px-4 py-3 text-center">
                  <div class="btn-group btn-group-sm">
                    <a href="/tasks/<%= task.task_id %>/edit" class="btn btn-outline-warning" title="Edit">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                      </svg>
                    </a>
                    <button class="btn btn-outline-danger btn-sm" onclick="deleteTask(<%= task.task_id %>)" title="Delete">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Back Button -->
    <div class="mt-4">
      <a href="/projects" class="btn btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
        </svg>
        Back to Projects
      </a>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function deleteTask(taskId) {
      if (confirm('Are you sure you want to delete this task?')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/tasks/${taskId}/delete`;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
</body>

</html>