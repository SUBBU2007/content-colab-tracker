```html
<!DOCTYPE html>
<html>
<head>
    <title>Edit Task - Content Collaboration Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Content Collaboration Tracker</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/projects">Projects</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/tasks">Tasks</a>
                    </li>
                    <li class="nav-item">
                        <span class="nav-link text-white-50">|</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/logout">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4 mb-5">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard" class="text-decoration-none">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/projects" class="text-decoration-none">Projects</a></li>
                <li class="breadcrumb-item"><a href="/projects/<%= task.project_id %>" class="text-decoration-none">Project Details</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit Task</li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!-- Header Card -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="text-warning" viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="mb-1 fw-bold">Edit Task</h3>
                                <p class="text-muted mb-0 small">Update task details and settings</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Card -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <form action="/tasks/<%= task.task_id %>/edit" method="POST">
                            <!-- Task Title -->
                            <div class="mb-4">
                                <label for="task_title" class="form-label fw-semibold">
                                    Task Title <span class="text-danger">*</span>
                                </label>
                                <input 
                                    type="text" 
                                    id="task_title"
                                    name="task_title" 
                                    class="form-control form-control-lg" 
                                    placeholder="e.g., Create intro animation, Implement user authentication"
                                    value="<%= task.task_title %>"
                                    required
                                >
                                <div class="form-text">Give your task a clear and descriptive title</div>
                            </div>

                            <!-- Description -->
                            <div class="mb-4">
                                <label for="description" class="form-label fw-semibold">
                                    Description
                                </label>
                                <textarea 
                                    id="description"
                                    name="description" 
                                    class="form-control" 
                                    rows="4"
                                    placeholder="Provide detailed instructions or context for this task..."
                                ><%= task.description || '' %></textarea>
                                <div class="form-text">Add any additional details or requirements</div>
                            </div>

                            <!-- Assigned To -->
                            <!-- <div class="mb-4">
                                <label for="assigned_to" class="form-label fw-semibold">
                                    Assign To
                                </label>
                                <select id="assigned_to" name="assigned_to" class="form-select form-select-lg">
                                    <option value="">Select team member</option>
                                    <option value="1" <%= task.assigned_to == 1 ? 'selected' : '' %>>John Doe</option>
                                    <option value="2" <%= task.assigned_to == 2 ? 'selected' : '' %>>Jane Smith</option>
                                    <option value="3" <%= task.assigned_to == 3 ? 'selected' : '' %>>Mike Johnson</option>
                                </select>
                                <div class="form-text">Choose who should work on this task</div>
                            </div> -->

                            <!-- Due Date -->
                            <div class="mb-4">
                                <label for="due_date" class="form-label fw-semibold">
                                    Due Date
                                </label>
                                <input 
                                    type="date" 
                                    id="due_date"
                                    name="due_date" 
                                    class="form-control form-control-lg"
                                    value="<%= task.due_date ? task.due_date.toISOString().split('T')[0] : '' %>"
                                >
                                <div class="form-text">Set a deadline for task completion</div>
                            </div>

                            <!-- Status Selection -->
                            <div class="mb-4">
                                <label for="status" class="form-label fw-semibold">
                                    Task Status
                                </label>
                                <select id="status" name="status" class="form-select form-select-lg">
                                    <option value="Pending" <%= task.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="In Progress" <%= task.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                                    <option value="Completed" <%= task.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                                </select>
                                <div class="form-text">Update the current status of this task</div>
                            </div>

                            <!-- Priority (Optional Enhancement) -->
                            <!-- <div class="mb-4">
                                <label for="priority" class="form-label fw-semibold">
                                    Priority
                                </label>
                                <select id="priority" name="priority" class="form-select form-select-lg">
                                    <option value="Low" <%= task.priority === 'Low' ? 'selected' : '' %>>Low</option>
                                    <option value="Medium" <%= task.priority === 'Medium' || !task.priority ? 'selected' : '' %>>Medium</option>
                                    <option value="High" <%= task.priority === 'High' ? 'selected' : '' %>>High</option>
                                </select>
                                <div class="form-text">Set the priority level for this task</div>
                            </div> -->

                            <!-- Action Buttons -->
                            <div class="d-flex gap-2 pt-3 border-top">
                                <button type="submit" class="btn btn-warning btn-lg px-4">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                                        <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z"/>
                                    </svg>
                                    Update Task
                                </button>
                                <a href="/projects/<%= task.project_id %>" class="btn btn-outline-secondary btn-lg px-4">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Warning Card -->
                <div class="card border-warning bg-warning bg-opacity-10 mt-4">
                    <div class="card-body p-4">
                        <h6 class="fw-semibold mb-3 text-warning">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                            </svg>
                            Important Notes
                        </h6>
                        <ul class="small text-muted mb-0 ps-3">
                            <li class="mb-2">Changes will be immediately visible to all team members</li>
                            <li class="mb-2">Marking a task as "Completed" will update project progress</li>
                            <li class="mb-0">Assigned team member will be notified of any changes</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
```